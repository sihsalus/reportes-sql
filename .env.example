# ── PostgreSQL (indicadores database) ────────────────────────────────────
INDICATORS_DB_HOST=localhost
INDICATORS_DB_PORT=5432
INDICATORS_DB_NAME=indicators
INDICATORS_DB_USER=postgres
INDICATORS_DB_PASSWORD=your_password

# ── MySQL (OpenMRS database) ─────────────────────────────────────────────
OPENMRS_DB_HOST=localhost
OPENMRS_DB_PORT=3306
OPENMRS_DB_NAME=openmrs
OPENMRS_DB_USER=root
OPENMRS_DB_PASSWORD=your_password

# ── OpenMRS REST API ─────────────────────────────────────────────────────
OPENMRS_API_URL=http://localhost/openmrs
OPENMRS_API_USER=admin
OPENMRS_API_PASSWORD=Admin123

# ── Application ──────────────────────────────────────────────────────────
PORT=8000

# Comma-separated list of allowed origins for CORS.
# Default (when empty): localhost:5173, localhost:8080 (and 127.0.0.1 equivalents).
# In production, set this to your gateway or SPA origin(s).
# CORS_ORIGINS=

# Seed a default indicator on startup (true|false).
# Useful in development; disable in production if you manage indicators yourself.
# Set to false to skip seeding a default indicator on startup
AUTO_SEED_DEFAULT_INDICATOR=true

# ── Routing ──────────────────────────────────────────────────────────────
# Base path for running behind a reverse proxy / API gateway.
# Empty = all routes mount at root (standalone dev).
# Set it when integrating behind a gateway, e.g.:
#   BASE_PATH=/openmrs/services/reportes-sql
# When set, routes are prefixed (e.g. /openmrs/services/reportes-sql/indicadores)
# but /health remains available at root for gateway health checks.
BASE_PATH=
